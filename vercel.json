{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "env": {
    "CHARGEOPT_SKIP_DB_MIGRATION": "1"
  },
  "installCommand": "pip install -r requirements-vercel.txt",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/health",
      "dest": "/api/index.py"
    },
    {
      "src": "/metrics",
      "dest": "/api/index.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/static/index.html"
    }
  ]
}
