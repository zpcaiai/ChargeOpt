{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python scripts/migrate.py",
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{tests/**,__pycache__/**,.pytest_cache/**,docs/**}"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/static/index.html"
    }
  ]
}
