# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=info

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to run in in-memory mode (Vercel / local demo)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=10
# Set to 1 to skip running migrations on startup (e.g. read-only replicas)
CHARGEOPT_SKIP_DB_MIGRATION=1

# ── Security ──────────────────────────────────────────────────────────────────
# Leave blank to disable API-key enforcement (development only)
API_KEY=
API_KEY_HEADER=X-API-Key
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=*

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true
